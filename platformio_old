[env:wt32-eth01]
platform = espressif32 @6.9.0
board = wt32-eth01
framework = arduino
lib_deps = 1
	adafruit/DHT sensor library@^1.4.7
	bblanchon/ArduinoJson@^7.2.2
	lennarthennigs/ESP Telnet@^2.2.3
	khoih-prog/WebServer_WT32_ETH01@^1.5.1
	;vshymanskyy/Preferences@^2.2.2
upload_protocol = espota
upload_port = 10.0.0.32
;upload_port = COM8;
;upload_port = COM4;
;monitor_port = COM8
;monitor_port = 10.0.0.33;
monitor_port = socket://10.0.0.32:23
monitor_speed = 115200
